MAX_ALUMNOS = 30

# VALIDACIÓNES 
def validar_legajo():
    """Funcion que verifica si el legado es un numero entero
    
    Args: none
    
    Returns: Si el legajo no es un numero entero, tira error y se queda 
    en bucle hasta que sea correcto
    """
    while True:
        entrada = input("Ingrese el número de legajo: ").strip()
        if entrada.isdigit():
            return int(entrada)
        print("Error: El legajo debe contener únicamente números enteros.")


 
def validar_nombre():
    """Funcion para verificar que un nombre no esté vacío 
    y contenga solo letras y espacios.
    
    Args: none
    
    Returns: Si el nombre no esta escrito correctamente tira error y hay que escribirlo 
    de nuevo
    """
    while True:
        entrada = input("Ingrese Apellido y Nombre: ").strip()
        if entrada.replace(" ", "").isalpha() and entrada != "":
            return entrada
        print("Error: El nombre debe contener solo letras y espacios.")


def validar_genero():
    """funcion para verificar que el genero este escrito correctamente
    (si o si en MAYUSCULA)
    
    Args: none
    
    Returns: si el genero esta mal escrito da error y hay que escribirlo de nuevo
    """
    while True:
        entrada = input("Ingrese el género (F / M / X): ").strip().upper()
        if entrada in ["F", "M", "X"]:
            return entrada
        print("Error: Género inválido. Opciones permitidas: F, M o X.")

def validar_nota(mensaje):
    """funcion que toma un parametro para pedir una nota
    
    Args: none
    
    Returns: Si la nota no esta comprendida entre 1 y 10, da error y hay que escribirla 
    de nuevo
    """
    while True:
        entrada = input(mensaje).strip()
        if entrada.isdigit():
            nota = int(entrada)
            if 1 <= nota <= 10:
                return nota
        print("Error: La nota debe ser un número entero entre 1 y 10.")

